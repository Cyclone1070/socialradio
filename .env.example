# Database Connection (Accepts a standard PostgreSQL connection URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socialradio

# Authentication
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production

# Browserless Chrome Container (For Playwright Scraping)
BROWSERLESS_WS_URL=ws://localhost:3000/playwright

# LLM Script Generation (DeepSeek or OpenAI-Compatible APIs like OpenCode/OpenRouter)
DEEPSEEK_API_KEY=your_deepseek_or_opencode_api_key_here
# Optional overrides for alternative providers:
# DEEPSEEK_BASE_URL=https://opencode.ai/zen/go/v1
# DEEPSEEK_MODEL=opencode/deepseek-chat

# Text-To-Speech Audio Generation (Google Cloud Studio TTS)
# Note: Google TTS can read TTS_API_KEY or fallback to GEMINI_API_KEY
TTS_API_KEY=your_google_cloud_api_key_here
GEMINI_API_KEY=your_google_cloud_api_key_here
